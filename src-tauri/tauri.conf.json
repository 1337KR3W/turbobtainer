{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "turbobtainer",
  "version": "1.0.0",
  "identifier": "com.turbobtainer.1337KR3W",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/turbobtainer/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Turbobtainer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/yt-dlp",
      "bin/ffmpeg"
    ]
  }
}