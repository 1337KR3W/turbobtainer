{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "turbobtainer",
  "version": "0.1.0",
  "identifier": "com.turbobtainer.1337KR3W",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/turbobtainer/browser"
  },
  "app": {
    "windows": [
      {
        "title": "turbobtainer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/yt-dlp"
    ]
  }
}