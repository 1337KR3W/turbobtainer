{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "turbobtainer",
  "version": "1.2.5",
  "identifier": "com.turbobtainer.1337KR3W",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/turbobtainer/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Turbobtainer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost http://localhost:4200; connect-src 'self' https://* http://*; frame-src 'self' https://streamwish.to https://*.awentub.com https://*.medixiru.com; img-src 'self' https://* http://* data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*; style-src 'self' 'unsafe-inline' https://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/yt-dlp",
      "bin/ffmpeg",
      "bin/gallery-dl"
    ],
    "resources": []
  }
}