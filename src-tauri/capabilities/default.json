{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "shell:allow-execute",
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://**"
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "sidecar": true,
          "name": "bin/yt-dlp"
        }
      ]
    }
  ]
}